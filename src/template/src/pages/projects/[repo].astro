---
import BaseLayout from '../../layouts/BaseLayout.astro';
import portfolio from '../../data/portfolio.json';

export function getStaticPaths() {
  return portfolio.repos
    .filter(r => r.enable !== false)
    .map(r => ({ params: { repo: r.name } }));
}

const { repo: repoName } = Astro.params;
const repo = portfolio.repos.find(r => r.name === repoName);
if (!repo) return Astro.redirect('/projects');

// ── Date helpers ────────────────────────────────────────────────────────────
function fmtDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
function fmtMonth(ym: string): string {
  const [y, m] = ym.split('-');
  return `${['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][parseInt(m) - 1]} ${y}`;
}

// ── Commit chart data ────────────────────────────────────────────────────────
type CommitMonth = { month: string; count: number };
type CommitWeek  = { week: string; count: number };
type CommitDay   = { day: string; count: number };
type ChartBar    = { key: string; count: number };

function fillWeekGaps(data: CommitWeek[]): CommitWeek[] {
  if (data.length === 0) return [];
  const result: CommitWeek[] = [];
  const countMap = new Map(data.map(d => [d.week, d.count]));
  const cur = new Date(data[0].week);
  const end = new Date(data[data.length - 1].week);
  while (cur <= end) {
    const key = `${cur.getFullYear()}-${String(cur.getMonth() + 1).padStart(2, '0')}-${String(cur.getDate()).padStart(2, '0')}`;
    result.push({ week: key, count: countMap.get(key) ?? 0 });
    cur.setDate(cur.getDate() + 7);
  }
  return result;
}

function fillDayGaps(data: CommitDay[]): CommitDay[] {
  if (data.length === 0) return [];
  const result: CommitDay[] = [];
  const countMap = new Map(data.map(d => [d.day, d.count]));
  const cur = new Date(data[0].day);
  const end = new Date(data[data.length - 1].day);
  while (cur <= end) {
    const key = `${cur.getFullYear()}-${String(cur.getMonth() + 1).padStart(2, '0')}-${String(cur.getDate()).padStart(2, '0')}`;
    result.push({ day: key, count: countMap.get(key) ?? 0 });
    cur.setDate(cur.getDate() + 1);
  }
  return result;
}

function fmtBarDate(dateStr: string): string {
  const d = new Date(dateStr);
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getMonth()]} ${String(d.getDate()).padStart(2, '0')}`;
}

const rawCommits: CommitMonth[] = (repo as any).commitsByMonth ?? [];
const rawWeeks: CommitWeek[]    = (repo as any).commitsByWeek ?? [];
const rawDays: CommitDay[]      = (repo as any).commitsByDay ?? [];

const weeksData = fillWeekGaps(rawWeeks);
const daysData  = fillDayGaps(rawDays);

// < 14 weeks → day view, otherwise → week view
const useDay = weeksData.length < 14;
const chartBars: ChartBar[] = useDay
  ? daysData.map(d => ({ key: d.day, count: d.count }))
  : weeksData.map(w => ({ key: w.week, count: w.count }));

const totalBars = chartBars.length;
const maxCount = totalBars > 0 ? Math.max(...chartBars.map(c => c.count), 1) : 1;

// SVG dimensions
const VW = 600;
const CH = 72;
const LH = 20;
const VH = CH + LH + 8;
const slotW = totalBars > 0 ? VW / totalBars : VW;
const barW = Math.max(1, slotW - 1);
const minBarH = 3;
const gridLines = [0.25, 0.5, 0.75].map(p => Math.round(CH * (1 - p)));
// Label every N bars to avoid overlap (~40px per label)
const labelEvery = Math.max(1, Math.ceil(totalBars / (VW / 40)));

// For day view: show label when crossing into new month
// For week view: show label when crossing into new month AND on labelEvery boundary
function showLabel(bars: ChartBar[], i: number): boolean {
  if (i === 0 || i === bars.length - 1) return true;
  const isNewMonth = bars[i].key.slice(0, 7) !== bars[i - 1].key.slice(0, 7);
  return isNewMonth && i % labelEvery === 0;
}

// ── Contributors ─────────────────────────────────────────────────────────────
type Contributor = { login: string; avatarUrl: string; name: string | null; count: number };
const contributors: Contributor[] = (repo as any).contributors ?? [];

// ── Language breakdown ───────────────────────────────────────────────────────
type Lang = { name: string; color: string; percentage: number };
const langs: Lang[] = (repo as any).languages ?? [];

// ── Disk size ─────────────────────────────────────────────────────────────────
const diskUsage: number = (repo as any).diskUsage ?? 0;
function fmtSize(kb: number): string {
  if (kb < 1024) return `${kb} KB`;
  return `${(kb / 1024).toFixed(1)} MB`;
}
---

<BaseLayout title={`${repo.name} — ${portfolio.meta.siteTitle}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <!-- Back link -->
    <a href="/projects" class="inline-flex items-center gap-1.5 text-sm text-stone-500 hover:text-stone-300 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      All projects
    </a>

    <!-- Header ─────────────────────────────────────────────────────────────── -->
    <div class="mb-10">
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <h1 class="mono text-3xl font-bold text-stone-100">{repo.name}</h1>
        {repo.isPrivate && (
          <span class="text-xs px-2 py-1 rounded border border-stone-700 text-stone-500 mono">private</span>
        )}
        {(repo as any).license && (
          <span class="text-xs px-2 py-1 rounded border border-stone-700 text-stone-500 mono">{(repo as any).license}</span>
        )}
      </div>

      <!-- Date range -->
      {repo.createdAt && repo.pushedAt && (
        <p class="mono text-sm text-stone-400 mb-4">
          {fmtDate(repo.createdAt)}
          <span class="text-stone-600 mx-2">→</span>
          {fmtDate(repo.pushedAt)}
        </p>
      )}

      <!-- Description -->
      <p class="text-stone-300 text-base leading-relaxed max-w-2xl">
        {repo.description ?? 'No description available.'}
      </p>

      <!-- Action links -->
      <div class="flex items-center gap-3 mt-5">
        {!repo.isPrivate && (
          <a href={repo.url} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-1.5 text-sm px-4 py-2 rounded-lg border border-stone-700 text-stone-300 hover:border-amber-500/50 hover:text-amber-400 transition-colors mono">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
          </a>
        )}
        {repo.homepageUrl && (
          <a href={repo.homepageUrl} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-1.5 text-sm px-4 py-2 rounded-lg border border-stone-700 text-stone-300 hover:border-amber-500/50 hover:text-amber-400 transition-colors mono">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Demo
          </a>
        )}
      </div>
    </div>

    <!-- Stats row ─────────────────────────────────────────────────────────── -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
      <div class="card py-4 text-center">
        <p class="text-2xl font-bold text-stone-100 mono">{repo.stars}</p>
        <p class="text-xs text-stone-500 mt-1">Stars</p>
      </div>
      <div class="card py-4 text-center">
        <p class="text-2xl font-bold text-stone-100 mono">{repo.forks}</p>
        <p class="text-xs text-stone-500 mt-1">Forks</p>
      </div>
      <div class="card py-4 text-center">
        <p class="text-2xl font-bold text-stone-100 mono">{rawCommits.reduce((s: number, c: CommitMonth) => s + c.count, 0)}</p>
        <p class="text-xs text-stone-500 mt-1">Commits tracked</p>
      </div>
      <div class="card py-4 text-center">
        <p class="text-2xl font-bold text-stone-100 mono">{fmtSize(diskUsage)}</p>
        <p class="text-xs text-stone-500 mt-1">Repo size</p>
      </div>
    </div>

    <!-- Commit frequency chart ─────────────────────────────────────────────── -->
    {chartBars.length > 0 && (
      <div class="card mb-8">
        <div class="flex items-baseline justify-between mb-4">
          <div class="flex items-center gap-2">
            <h2 class="text-lg font-semibold text-stone-100">Commit Activity</h2>
            <span class="text-xs px-1.5 py-0.5 rounded border border-stone-700 text-stone-500 mono">
              {useDay ? 'daily' : 'weekly'}
            </span>
          </div>
          <span class="text-xs text-stone-500 mono">
            {fmtBarDate(chartBars[0].key)} – {fmtBarDate(chartBars[chartBars.length - 1].key)}
          </span>
        </div>
        <svg
          viewBox={`0 0 ${VW} ${VH}`}
          width="100%"
          style="display:block"
          aria-label="Commit frequency chart"
        >
          <!-- Gridlines -->
          {gridLines.map(gy => (
            <line x1="0" y1={gy} x2={VW} y2={gy} stroke="#292524" stroke-width="1" />
          ))}
          <!-- Bars -->
          {chartBars.map((c: ChartBar, i: number) => {
            const rawH = c.count > 0 ? Math.max(minBarH, Math.round((c.count / maxCount) * CH)) : 0;
            const x = i * slotW;
            const label = showLabel(chartBars, i);
            const prefix = useDay ? '' : 'Week of ';
            return (
              <g>
                {c.count > 0 && (
                  <rect
                    x={x + 0.5}
                    y={CH - rawH}
                    width={barW}
                    height={rawH}
                    rx="1"
                    fill="#f59e0b"
                    opacity={0.4 + 0.6 * (c.count / maxCount)}
                  >
                    <title>{prefix}{fmtBarDate(c.key)}: {c.count} commit{c.count !== 1 ? 's' : ''}</title>
                  </rect>
                )}
                {label && (
                  <text
                    x={x + slotW / 2}
                    y={CH + LH + 2}
                    text-anchor="middle"
                    font-size="9"
                    fill="#78716c"
                    font-family="monospace"
                  >
                    {c.key.slice(5, 7)}/{c.key.slice(8, 10)}
                  </text>
                )}
              </g>
            );
          })}
          <!-- Baseline -->
          <line x1="0" y1={CH} x2={VW} y2={CH} stroke="#44403c" stroke-width="1" />
        </svg>
        <p class="text-xs text-stone-600 mt-2 mono">* Based on up to 100 most recent commits on default branch</p>
      </div>
    )}

    <!-- Language breakdown ─────────────────────────────────────────────────── -->
    {langs.length > 0 && (
      <div class="card mb-8">
        <h2 class="text-lg font-semibold text-stone-100 mb-4">Languages</h2>
        <div class="flex h-3 rounded-full overflow-hidden mb-4 bg-stone-800">
          {langs.map((lang: Lang) => (
            <div
              style={`width: ${lang.percentage}%; background-color: ${lang.color};`}
              title={`${lang.name} ${lang.percentage}%`}
            />
          ))}
        </div>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          {langs.map((lang: Lang) => (
            <span class="flex items-center gap-1.5 text-sm text-stone-400 mono">
              <span class="w-3 h-3 rounded-full flex-shrink-0" style={`background-color: ${lang.color};`} />
              {lang.name}
              <span class="text-stone-600">{lang.percentage}%</span>
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Contributors ─────────────────────────────────────────────────────── -->
    {!repo.isPrivate && contributors.length > 0 && (
      <div class="card mb-8">
        <h2 class="text-lg font-semibold text-stone-100 mb-4">Contributors</h2>
        <div class="flex flex-wrap gap-3">
          {contributors.map((c: Contributor) => (
            <a
              href={`https://github.com/${c.login}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2.5 px-3 py-2 rounded-lg border border-stone-800 hover:border-stone-700 transition-colors"
            >
              <img
                src={c.avatarUrl}
                alt={c.login}
                width="28"
                height="28"
                class="rounded-full"
              />
              <div class="text-left">
                <p class="text-sm text-stone-200 mono leading-tight">{c.login}</p>
                <p class="text-xs text-stone-500">{c.count} commit{c.count !== 1 ? 's' : ''}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Topics & Skills ────────────────────────────────────────────────────── -->
    {(repo.topics.length > 0 || (repo.matchedSkills && repo.matchedSkills.length > 0)) && (
      <div class="card mb-8">
        <h2 class="text-lg font-semibold text-stone-100 mb-4">Tags</h2>
        {repo.topics.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-3">
            {repo.topics.map((topic: string) => (
              <span class="tag">{topic}</span>
            ))}
          </div>
        )}
        {repo.matchedSkills && repo.matchedSkills.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {repo.matchedSkills.map((skill: string) => (
              <span class="text-xs px-2 py-0.5 rounded-full border border-amber-500/30 text-amber-400/80 mono">
                {skill}
              </span>
            ))}
          </div>
        )}
      </div>
    )}

  </div>
</BaseLayout>
