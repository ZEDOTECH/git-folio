---
import BaseLayout from '../layouts/BaseLayout.astro';
import portfolio from '../data/portfolio.json';

const repos = portfolio.repos.filter(r => r.enable !== false);
const languages = [...new Set(repos.map(r => r.primaryLanguage?.name).filter(Boolean))].sort() as string[];

function ym(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
}
---

<BaseLayout title={`Projects — ${portfolio.meta.siteTitle}`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-stone-100 mb-2">Projects</h1>
      <p class="text-stone-500 mono text-sm">{repos.length} repositories</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-col sm:flex-row gap-3 mb-8">
      <input
        id="search"
        type="text"
        placeholder="Search by name or description..."
        class="flex-1 bg-stone-900 border border-stone-800 rounded-lg px-4 py-2.5 text-sm text-stone-100 placeholder-stone-600 focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/20 transition-colors"
      />
      <select
        id="lang-filter"
        class="bg-stone-900 border border-stone-800 rounded-lg px-4 py-2.5 text-sm text-stone-300 focus:outline-none focus:border-amber-500/50 transition-colors sm:w-44"
      >
        <option value="">All languages</option>
        {languages.map(lang => (
          <option value={lang.toLowerCase()}>{lang}</option>
        ))}
      </select>
    </div>

    <!-- Grid -->
    <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {repos.map(repo => (
        <div
          class="project-item card group flex flex-col h-full"
          data-name={`${repo.name} ${repo.description ?? ''}`.toLowerCase()}
          data-lang={repo.primaryLanguage?.name.toLowerCase() ?? ''}
        >
          <!-- Header -->
          <div class="flex items-start gap-2 mb-3">
            <svg class="w-4 h-4 text-stone-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
            </svg>
            <span class="mono font-semibold text-stone-100 leading-tight flex-1 min-w-0 truncate">{repo.name}</span>
            {repo.isPrivate && (
              <span class="flex-shrink-0 text-xs px-1.5 py-0.5 rounded border border-stone-700 text-stone-500 mono">
                private
              </span>
            )}
            {!repo.isPrivate && (
              <a
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                title="Open on GitHub"
                class="flex-shrink-0 text-xs px-1.5 py-0.5 rounded border border-stone-700 text-stone-400 mono hover:border-amber-500/50 hover:text-amber-400 transition-colors"
              >
                ↗
              </a>
            )}
            <a
              href={`/projects/${repo.name}`}
              title="View details"
              class="flex-shrink-0 text-xs px-1.5 py-0.5 rounded border border-stone-700 text-stone-400 mono hover:border-amber-500/50 hover:text-amber-400 transition-colors"
            >
              info
            </a>
          </div>

          {repo.createdAt && repo.pushedAt && (
            <p class="mono text-xs text-stone-100 mb-3">{ym(repo.createdAt)} ~ {ym(repo.pushedAt)}</p>
          )}

          <p class="text-stone-400 text-sm leading-relaxed flex-1 mb-4">
            {repo.description ?? 'No description available.'}
          </p>

          <!-- Language breakdown -->
          {repo.languages && repo.languages.length > 0 && (
            <div class="mb-3">
              <div class="flex h-1.5 rounded-full overflow-hidden mb-2 bg-stone-800">
                {repo.languages.map((lang: { name: string; color: string; percentage: number }) => (
                  <div
                    style={`width: ${lang.percentage}%; background-color: ${lang.color};`}
                    title={`${lang.name} ${lang.percentage}%`}
                  />
                ))}
              </div>
              <div class="flex flex-wrap gap-x-3 gap-y-1">
                {repo.languages.map((lang: { name: string; color: string; percentage: number }) => (
                  <span class="flex items-center gap-1 text-xs text-stone-400 mono">
                    <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background-color: ${lang.color};`} />
                    {lang.name}
                    <span class="text-stone-600">{lang.percentage}%</span>
                  </span>
                ))}
              </div>
            </div>
          )}

          {repo.topics.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-3">
              {repo.topics.slice(0, 4).map(topic => (
                <span class="tag">{topic}</span>
              ))}
            </div>
          )}

          <!-- Matched skills -->
          {repo.matchedSkills && repo.matchedSkills.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-3">
              {repo.matchedSkills.map((skill: string) => (
                <span class="text-xs px-2 py-0.5 rounded-full border border-amber-500/30 text-amber-400/80 mono">
                  {skill}
                </span>
              ))}
            </div>
          )}

          <div class="flex items-center justify-between mt-auto pt-4 border-t border-stone-800">
            <div class="flex items-center gap-4 text-xs text-stone-500">
              <span>★ {repo.stars}</span>
              <span>⑂ {repo.forks}</span>
            </div>
            <div class="flex items-center gap-3">
              {!repo.isPrivate && (
                <a href={repo.url} target="_blank" rel="noopener noreferrer" class="btn-ghost text-xs">GitHub →</a>
              )}
              {repo.homepageUrl && (
                <a href={repo.homepageUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost text-xs">Demo →</a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16 text-stone-500">
      <p class="text-lg mb-1">No projects found</p>
      <p class="text-sm">Try adjusting your search or filter</p>
    </div>
  </div>
</BaseLayout>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const langFilter = document.getElementById('lang-filter') as HTMLSelectElement;
  const items = document.querySelectorAll<HTMLElement>('.project-item');
  const emptyState = document.getElementById('empty-state')!;

  function applyFilter() {
    const q = search.value.toLowerCase().trim();
    const lang = langFilter.value.toLowerCase();
    let visible = 0;

    items.forEach(el => {
      const nameMatch = !q || (el.dataset.name ?? '').includes(q);
      const langMatch = !lang || el.dataset.lang === lang;
      const show = nameMatch && langMatch;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    emptyState.classList.toggle('hidden', visible > 0);
  }

  search.addEventListener('input', applyFilter);
  langFilter.addEventListener('change', applyFilter);
</script>
